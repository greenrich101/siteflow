generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Job {
  id              String    @id @default(cuid())
  jobNumber       String    @unique
  clientName      String
  siteAddress     String
  phone           String?
  email           String?
  phase           String    @default("quoting")
  quoteAmount     Float?
  quoteSentDate   DateTime?
  contractSigned  DateTime?
  startDate       DateTime?
  targetEndDate   DateTime?
  percentComplete Float     @default(0)
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  variations     Variation[]
  progressClaims ProgressClaim[]
  documents      Document[]
  dailyLogs      DailyLog[]
  jobSubbies     JobSubbie[]
}

model Variation {
  id          String   @id @default(cuid())
  jobId       String
  title       String
  description String?
  amount      Float
  status      String   @default("pending")
  createdAt   DateTime @default(now())

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model ProgressClaim {
  id          String    @id @default(cuid())
  jobId       String
  claimNumber Int
  amount      Float
  dateSent    DateTime
  datePaid    DateTime?
  status      String    @default("sent")
  createdAt   DateTime  @default(now())

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model Document {
  id         String   @id @default(cuid())
  jobId      String
  folder     String
  subfolder  String?
  fileName   String
  filePath   String
  uploadedAt DateTime @default(now())

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model DailyLog {
  id        String   @id @default(cuid())
  jobId     String
  date      DateTime
  notes     String
  weather   String?
  onSite    String?
  createdAt DateTime @default(now())

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model Subcontractor {
  id              String    @id @default(cuid())
  trade           String
  companyName     String
  contactName     String?
  phone           String?
  email           String?
  address         String?
  abn             String?
  gstRegistered   String?
  insuranceExpiry DateTime?
  rateBasis       String?
  rating          Int?
  notes           String?
  createdAt       DateTime  @default(now())

  // Onboarding fields
  emergencyContactName  String?
  emergencyContactPhone String?
  licenceNumber         String?
  licenceExpiry         DateTime?
  whiteCardNumber       String?
  whiteCardState        String?
  additionalTickets     String?
  licenceDocPath        String?
  pliProvider           String?
  pliPolicyNumber       String?
  pliCoverAmount        String?
  pliExpiry             DateTime?
  wcPolicyNumber        String?
  wcExpiry              DateTime?
  insuranceDocPath      String?
  siteInduction         String?
  ackSWMS               Boolean   @default(false)
  ackPPE                Boolean   @default(false)
  ackIncidentReporting  Boolean   @default(false)
  ackDrugAlcohol        Boolean   @default(false)
  ackEnvironmental      Boolean   @default(false)
  whsNotes              String?
  onboardingComplete    Boolean   @default(false)

  jobSubbies JobSubbie[]
}

model JobSubbie {
  id              String    @id @default(cuid())
  jobId           String
  subcontractorId String
  quoteAmount     Float?
  status          String    @default("quoted")
  scheduledStart  DateTime?
  scheduledEnd    DateTime?

  job           Job           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  subcontractor Subcontractor @relation(fields: [subcontractorId], references: [id], onDelete: Cascade)
}

model Settings {
  id            String @id @default("default")
  businessName  String @default("")
  abn           String @default("")
  phone         String @default("")
  email         String @default("")
  address       String @default("")
  jobPrefix     String @default("FO-")
  nextJobNumber Int    @default(4)
}
